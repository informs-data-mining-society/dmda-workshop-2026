---
import { ArrowUpRight, Menu, X } from 'lucide-astro';
import site from '@/data/site.json';

const base = import.meta.env.BASE_URL;
const navItems = [
  { label: 'About', href: `${base}#about` },
  { label: 'Call for Papers', href: `${base}#call-for-papers` },
  { label: 'Program', href: `${base}#program` },
  { label: 'Venue', href: `${base}#venue` },
  { label: 'Organizers', href: `${base}#organizers` },
  { label: 'Past Workshops', href: `${base}#past-workshops` }
];
---

<div class="society-bar">
  <div class="container society-bar__inner">
    <span>Sponsored by the INFORMS Data Mining Society</span>
    <a href={site.annualMeetingUrl} target="_blank" rel="noreferrer">
      2026 Annual Meeting <ArrowUpRight size={14} strokeWidth={1.8} />
    </a>
  </div>
</div>

<header class="site-header" data-header>
  <div class="container header-inner">
    <a class="brand" href={`${base}#top`} aria-label="DMDA 2026 home">
      <span class="brand-mark" aria-hidden="true"><b>DM</b><b>DA</b></span>
      <span class="brand-copy"><strong>DMDA</strong><small>San Francisco · 2026</small></span>
    </a>

    <button class="nav-toggle" type="button" aria-label="Open navigation" aria-expanded="false" aria-controls="site-nav">
      <Menu class="nav-open-icon" size={22} />
      <X class="nav-close-icon" size={22} />
    </button>

    <nav class="site-nav" id="site-nav" aria-label="Primary navigation">
      {navItems.map((item) => (
        <a href={item.href} data-section-link>{item.label}</a>
      ))}
      <a class="nav-submit" href={site.submissionUrl} target="_blank" rel="noreferrer">
        Submit a paper <ArrowUpRight size={15} />
      </a>
    </nav>
  </div>
</header>

<script>
  const header = document.querySelector('[data-header]');
  const toggle = header?.querySelector<HTMLButtonElement>('.nav-toggle');
  const nav = header?.querySelector<HTMLElement>('.site-nav');

  toggle?.addEventListener('click', () => {
    const isOpen = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!isOpen));
    toggle.setAttribute('aria-label', isOpen ? 'Open navigation' : 'Close navigation');
    nav?.classList.toggle('is-open', !isOpen);
  });

  nav?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      toggle?.setAttribute('aria-expanded', 'false');
      nav.classList.remove('is-open');
    });
  });

  const sectionLinks = Array.from(document.querySelectorAll<HTMLAnchorElement>('[data-section-link]'));
  const sectionById = new Map(
    sectionLinks
      .map((link) => [link.hash.slice(1), link] as const)
      .filter(([id]) => id.length > 0)
  );

  const setCurrentSection = (id: string) => {
    sectionLinks.forEach((link) => link.removeAttribute('aria-current'));
    sectionById.get(id)?.setAttribute('aria-current', 'location');
  };

  if ('IntersectionObserver' in window && sectionById.size > 0) {
    const observer = new IntersectionObserver(
      (entries) => {
        const visible = entries
          .filter((entry) => entry.isIntersecting)
          .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];
        if (visible?.target.id) setCurrentSection(visible.target.id);
      },
      { rootMargin: '-35% 0px -55% 0px', threshold: [0, 0.2, 0.5, 0.8] }
    );

    sectionById.forEach((_link, id) => {
      const section = document.getElementById(id);
      if (section) observer.observe(section);
    });
  }
</script>
