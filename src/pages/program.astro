---
import { CalendarDays, Download, Info } from 'lucide-astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHero from '@/components/PageHero.astro';
import site from '@/data/site.json';
---

<BaseLayout title={`Program | ${site.shortName}`} description="The DMDA 2026 workshop program will be posted here as sessions and speakers are confirmed.">
  <PageHero eyebrow="Saturday, October 31" title="Program" intro="A one-day program of research talks, invited perspectives, and conversations on data mining and decision analytics." />
  <section class="section section--white">
    <div class="container program-shell">
      <div class="program-notice">
        <Info size={25} />
        <div>
          <h2>The schedule is taking shape.</h2>
          <p>Session times, speakers, and room assignments will be published here as the program is finalized. Check back for the complete workshop schedule.</p>
        </div>
      </div>
      <div class="program-preview">
        <div class="program-day"><CalendarDays size={19} /><strong>October 31, 2026</strong><span>San Francisco · In person</span></div>
        <div class="program-row"><time>07:30</time><span>Workshop registration and welcome</span><em>Details coming soon</em></div>
        <div class="program-row"><time>09:00</time><span>Research presentations and invited sessions</span><em>Details coming soon</em></div>
        <div class="program-row"><time>12:00</time><span>Lunch and community conversations</span><em>Details coming soon</em></div>
        <div class="program-row"><time>13:30</time><span>Research presentations and panels</span><em>Details coming soon</em></div>
        <div class="program-row"><time>17:00</time><span>Workshop close</span><em>Details coming soon</em></div>
      </div>
      <div class="program-links">
        <a class="button button--secondary" href={site.officialUrl} target="_blank" rel="noreferrer"><Download size={16} /> Official INFORMS listing</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .program-shell { max-width: 900px; }
  .program-notice { display: grid; grid-template-columns: 32px 1fr; gap: 16px; padding: 28px; color: var(--white); background: var(--teal-dark); border-left: 7px solid var(--yellow); }
  .program-notice svg { color: var(--yellow); }
  .program-notice h2 { margin-bottom: 9px; font-size: 29px; }
  .program-notice p { max-width: 650px; margin-bottom: 0; color: rgba(255, 253, 250, .75); }
  .program-preview { margin-top: 58px; border-top: 1px solid var(--line); }
  .program-day { display: flex; align-items: center; gap: 12px; padding: 18px 0; color: var(--teal-dark); border-bottom: 3px solid var(--teal-dark); }
  .program-day span { margin-left: auto; color: var(--ink-soft); font-size: 13px; }
  .program-row { min-height: 79px; display: grid; grid-template-columns: 100px 1fr 155px; gap: 20px; align-items: center; border-bottom: 1px solid var(--line); }
  .program-row time { color: var(--red); font-family: var(--serif); font-size: 20px; }
  .program-row span { font-weight: 650; }
  .program-row em { color: var(--ink-soft); font-size: 12px; font-style: normal; }
  .program-links { margin-top: 28px; }
  @media (max-width: 600px) {
    .program-notice { padding: 22px; }
    .program-day { align-items: flex-start; flex-wrap: wrap; }
    .program-day span { width: 100%; margin-left: 31px; }
    .program-row { grid-template-columns: 68px 1fr; gap: 8px 15px; padding: 14px 0; }
    .program-row em { grid-column: 2; }
  }
</style>
