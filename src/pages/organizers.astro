---
import { ArrowUpRight, Mail } from 'lucide-astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHero from '@/components/PageHero.astro';
import organizers from '@/data/organizers.json';
import site from '@/data/site.json';
---

<BaseLayout title={`Organizers | ${site.shortName}`} description="Meet the co-chairs organizing the 21st INFORMS Workshop on Data Mining and Decision Analytics.">
  <PageHero eyebrow="INFORMS Data Mining Society" title="Workshop co-chairs" intro="DMDA is organized by four researchers working across data mining, machine learning, optimization, and decision analytics." />
  <section class="section section--white">
    <div class="container people-grid">
      {organizers.map((organizer, index) => (
        <article class="person">
          <div class="person-top"><span class="person-index">0{index + 1}</span><span class="person-initials">{organizer.name.split(' ').map((part) => part[0]).join('')}</span></div>
          <h2>{organizer.name}</h2>
          <p>{organizer.institution}</p>
          <div class="person-links"><a href={`mailto:${organizer.email}`}><Mail size={14} /> {organizer.email}</a><a href={organizer.website} target="_blank" rel="noreferrer">Profile <ArrowUpRight size={14} /></a></div>
        </article>
      ))}
    </div>
  </section>
  <section class="section section--ink contact-section"><div class="container"><span class="kicker kicker--light">Questions</span><h2>We look forward to hearing from you.</h2><p>For questions about submissions or the program, contact the co-chairs directly.</p></div></section>
</BaseLayout>

<style>
  .people-grid { display: grid; grid-template-columns: 1fr 1fr; border-top: 1px solid var(--line); border-left: 1px solid var(--line); }
  .person { min-height: 310px; padding: 31px; border-right: 1px solid var(--line); border-bottom: 1px solid var(--line); }
  .person-top { display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 38px; }
  .person-index { color: var(--red); font-family: var(--serif); font-size: 17px; }
  .person-initials { width: 64px; height: 64px; display: grid; place-items: center; color: var(--white); background: var(--teal); border-radius: 50%; font-family: var(--serif); font-size: 19px; }
  .person h2 { margin-bottom: 8px; font-size: 32px; }
  .person > p { margin-bottom: 27px; color: var(--ink-soft); }
  .person-links { display: flex; flex-wrap: wrap; gap: 15px; }
  .person-links a { display: inline-flex; align-items: center; gap: 5px; color: var(--teal-dark); font-size: 12px; font-weight: 700; text-decoration: none; }
  .contact-section h2 { max-width: 680px; margin-bottom: 15px; font-size: 52px; }
  .contact-section p { color: rgba(255, 253, 250, .73); font-size: 17px; }
  @media (max-width: 650px) { .people-grid { grid-template-columns: 1fr; } .person { min-height: auto; padding: 24px; } .contact-section h2 { font-size: 39px; } }
</style>
