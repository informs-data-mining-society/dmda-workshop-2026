---
import {
  ArrowRight,
  ArrowUpRight,
  CalendarDays,
  CheckCircle2,
  FileText,
  MapPin,
  Send,
  Trophy
} from 'lucide-astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import DeadlineTimeline from '@/components/DeadlineTimeline.astro';
import pastWorkshops from '@/data/past-workshops.json';
import site from '@/data/site.json';
import organizers from '@/data/organizers.json';
import topics from '@/data/topics.json';

const base = import.meta.env.BASE_URL;
const eventJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Event',
  name: `${site.edition} ${site.name}`,
  description: site.description,
  startDate: site.startDate,
  endDate: site.endDate,
  eventStatus: 'https://schema.org/EventScheduled',
  eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
  location: {
    '@type': 'Place',
    name: site.venue,
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'San Francisco',
      addressRegion: 'CA',
      addressCountry: 'US'
    }
  },
  image: [`https://informs-data-mining-society.github.io${base}images/san-francisco-hero.png`],
  organizer: {
    '@type': 'Organization',
    name: site.sponsor,
    url: 'https://connect.informs.org/data-mining/home'
  },
  offers: {
    '@type': 'Offer',
    url: site.registrationUrl,
    availability: 'https://schema.org/InStock',
    validThrough: '2026-10-17T23:59:00-04:00'
  }
};
const sponsorshipTiers = [
  { level: 'Platinum Level', detail: 'Sponsor recognition will be listed here.' },
  { level: 'Gold Level', detail: 'Sponsor recognition will be listed here.' },
  { level: 'Silver Level', detail: 'Sponsor recognition will be listed here.' }
];
---

<BaseLayout jsonLd={eventJsonLd}>
  <section class="home-hero" id="top" style={`--hero-image: url("${base}images/san-francisco-hero.png")`}>
    <div class="container home-hero__inner">
      <span class="hero-eyebrow">The {site.edition} INFORMS Workshop</span>
      <h1>Data Mining &<br />Decision Analytics</h1>
      <p>A focused day for consequential research at the intersection of data, learning, optimization, and decisions.</p>
      <div class="hero-actions">
        <a class="button button--primary" href={site.submissionUrl} target="_blank" rel="noreferrer">
          <Send size={17} /> Submit a paper <ArrowUpRight size={16} />
        </a>
        <a class="button button--light" href={`${base}#call-for-papers`}>
          Read the call for papers <ArrowRight size={16} />
        </a>
      </div>
    </div>
  </section>

  <section class="event-ribbon" aria-label="Workshop essentials">
    <div class="container event-ribbon__grid">
      <div><CalendarDays size={20} /><span><small>Date</small><strong>{site.date}</strong></span></div>
      <div class="event-location">
        <MapPin size={20} />
        <span>
          <small>Location</small>
          <strong>{site.city}</strong>
          <span class="venue-addresses">Moscone Center South, 747 Howard Street<br />Marriott Marquis San Francisco, 780 Mission Street</span>
        </span>
      </div>
      <div class="deadline-countdown">
        <span><small>Paper deadline</small><strong>August 1 · 11:59 PM ET</strong></span>
      </div>
    </div>
  </section>

  <section class="section section--white intro-section" id="about">
    <div class="container intro-grid">
      <div>
        <span class="kicker">About the workshop</span>
        <h2>From patterns in data to decisions that matter.</h2>
      </div>
      <div class="intro-copy">
        <p>The INFORMS Data Mining Society invites researchers and practitioners to share recent work in data mining, decision analytics, artificial intelligence, machine learning, optimization, and related methodological and applied areas.</p>
        <p>Held the day before the 2026 INFORMS Annual Meeting, DMDA brings together theoretical advances and field-tested applications in a focused, in-person setting.</p>
        <a class="button button--text" href={site.officialUrl} target="_blank" rel="noreferrer">
          View the official INFORMS listing <ArrowUpRight size={16} />
        </a>
      </div>
    </div>
  </section>

  <section class="section deadline-section" id="call-for-papers">
    <div class="container">
      <div class="section-heading">
        <span class="kicker">Call for Papers</span>
        <h2>Submit to the DMDA 2026 paper competition.</h2>
        <p>The INFORMS Data Mining Society invites full-paper submissions presenting methodological or applied research in data mining, decision analytics, artificial intelligence, machine learning, optimization, and related fields.</p>
      </div>
      <div class="competition-note">
        <Trophy size={26} />
        <div>
          <strong>Paper competition</strong>
          <p>Submitted papers are reviewed for the DMDA Workshop Best Paper Competition in theoretical and applied research tracks. Four finalists will be selected for each track.</p>
        </div>
      </div>
      <div class="cfp-grid">
        <article>
          <h3>Paper format</h3>
          <ul class="check-list">
            <li><CheckCircle2 size={18} /><span>Maximum of 10 pages total, including abstract, tables, figures, references, appendices, and all other material.</span></li>
            <li><CheckCircle2 size={18} /><span>One-inch margins, 11-point font or larger, single-column and single-spaced.</span></li>
            <li><CheckCircle2 size={18} /><span>Include a 50-word abstract.</span></li>
            <li><CheckCircle2 size={18} /><span>Prepare both a blinded and an unblinded PDF.</span></li>
          </ul>
        </article>
        <article>
          <h3>Eligibility and review</h3>
          <ul class="plain-list">
            <li>The award nominee or lead author must be a member of the INFORMS Data Mining Society at the time of the 2026 Annual Meeting.</li>
            <li>Submitted work must be neither published nor accepted for publication elsewhere at the time of submission.</li>
            <li>An author may serve as lead author on at most one submission per competition track.</li>
            <li>Review is double-blind. Four finalists will be selected for each track by external referees.</li>
          </ul>
        </article>
      </div>
      <div class="cfp-topics">
        <h3>Topics of interest</h3>
        <ul class="topic-list">
          {topics.map((topic) => <li>{topic}</li>)}
        </ul>
      </div>
      <div class="section-heading section-heading--compact">
        <span class="kicker">Important dates</span>
        <h2>Four dates to keep in view.</h2>
      </div>
      <DeadlineTimeline />
      <div class="deadline-actions">
        <a class="button button--primary" href={site.submissionUrl} target="_blank" rel="noreferrer">
          Submit through Google Forms <ArrowUpRight size={16} />
        </a>
        <a class="button button--secondary" href={site.cfpUrl} target="_blank" rel="noreferrer">
          <FileText size={16} /> View official CFP <ArrowUpRight size={16} />
        </a>
      </div>
    </div>
  </section>

  <section class="section section--white program-section" id="program">
    <div class="container program-shell">
      <div class="section-heading">
        <span class="kicker">Program</span>
        <h2>A one-day program in San Francisco.</h2>
        <p>Session times, speakers, and room assignments will be published as the program is finalized.</p>
      </div>
      <div class="program-preview">
        <div class="program-day"><CalendarDays size={19} /><strong>October 31, 2026</strong><span>San Francisco · In person</span></div>
        <div class="program-row"><time>07:30</time><span>Workshop registration and welcome</span><em>Details coming soon</em></div>
        <div class="program-row"><time>09:00</time><span>Research presentations and invited sessions</span><em>Details coming soon</em></div>
        <div class="program-row"><time>12:00</time><span>Lunch and community conversations</span><em>Details coming soon</em></div>
        <div class="program-row"><time>13:30</time><span>Research presentations and panels</span><em>Details coming soon</em></div>
        <div class="program-row"><time>17:00</time><span>Workshop close</span><em>Details coming soon</em></div>
      </div>
    </div>
  </section>

  <section class="section sponsorship-section" id="sponsorships">
    <div class="container">
      <div class="sponsorship-head">
        <div class="section-heading">
          <span class="kicker">Sponsorships</span>
          <h2>DMDA 2026 sponsorships.</h2>
          <p>Sponsorship opportunities are organized in three tiers. Sponsor names and logos will be listed here as commitments are confirmed.</p>
        </div>
        <a class="button button--secondary" href={`mailto:${organizers[0].email}`}>
          Contact the co-chairs <ArrowRight size={16} />
        </a>
      </div>
      <div class="sponsorship-tiers">
        {sponsorshipTiers.map((tier) => (
          <article class="sponsorship-tier">
            <span>{tier.level}</span>
            <p>{tier.detail}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--white organizer-section" id="organizers">
    <div class="container">
      <div class="organizer-heading">
        <h2>Workshop co-chairs</h2>
      </div>
      <div class="organizer-row">
        {organizers.map((organizer) => (
          <article class="organizer-mini">
            <span class="organizer-initials" aria-hidden="true">
              {organizer.name.split(' ').map((part) => part[0]).join('')}
            </span>
            <h3>{organizer.name}</h3>
            <a class="organizer-email" href={`mailto:${organizer.email}`}>{organizer.email}</a>
            <p>{organizer.institution}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section past-section" id="past-workshops">
    <div class="container past-compact">
      <div>
        <span class="kicker">Past Workshops</span>
        <h2>Recent DMDA workshops.</h2>
      </div>
      <ul class="past-links">
        <li><a href={`${base}#top`}>2026 · San Francisco</a><span>21st · Current</span></li>
        {pastWorkshops.map((event) => (
          <li><a href={event.url} target="_blank" rel="noreferrer">{event.year} · {event.city}</a><span>{event.edition}</span></li>
        ))}
      </ul>
    </div>
  </section>
</BaseLayout>

<style>
  .home-hero {
    position: relative;
    min-height: min(650px, calc(100svh - 154px));
    display: grid;
    align-items: center;
    overflow: hidden;
    color: var(--white);
    background-color: #002676;
    background-image: var(--hero-image);
    background-position: center;
    background-size: cover;
  }

  .home-hero::before {
    position: absolute;
    inset: 0;
    content: '';
    background: rgba(0, 20, 75, 0.64);
  }

  .home-hero__inner {
    position: relative;
    z-index: 1;
    padding-block: 62px;
  }

  .hero-eyebrow {
    display: block;
    margin-bottom: 17px;
    color: var(--yellow);
    font-size: 13px;
    font-weight: 800;
    text-transform: uppercase;
  }

  .home-hero h1 {
    max-width: 880px;
    margin-bottom: 22px;
    font-size: 76px;
    text-wrap: balance;
  }

  .home-hero p {
    max-width: 670px;
    margin-bottom: 30px;
    color: rgba(255, 253, 250, 0.84);
    font-size: 19px;
  }

  .hero-actions,
  .deadline-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .event-ribbon {
    color: var(--white);
    background: var(--teal-dark);
  }

  .event-ribbon__grid {
    min-height: 104px;
    display: grid;
    grid-template-columns: 0.75fr 1.65fr 0.95fr;
  }

  .event-ribbon__grid > div {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 20px 30px;
    border-right: 1px solid rgba(255, 253, 250, 0.17);
  }

  .event-ribbon__grid > div:first-child {
    padding-left: 0;
  }

  .event-ribbon__grid > div:last-child {
    padding-right: 0;
    border-right: 0;
  }

  .event-ribbon span {
    display: grid;
  }

  .event-ribbon small {
    color: rgba(255, 253, 250, 0.6);
    font-size: 10px;
    font-weight: 750;
    text-transform: uppercase;
  }

  .event-ribbon strong {
    font-size: 14px;
  }

  .venue-addresses {
    margin-top: 5px;
    color: rgba(255, 253, 250, 0.68);
    font-size: 12px;
    line-height: 1.35;
  }

  .intro-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 90px;
  }

  .intro-grid h2 {
    margin-bottom: 0;
    font-size: 51px;
  }

  .intro-copy p {
    color: var(--ink-soft);
    font-size: 17px;
  }

  .intro-copy .button {
    margin-top: 9px;
  }

  .deadline-actions {
    margin-top: 30px;
  }

  .section-heading--compact {
    margin-top: 46px;
    margin-bottom: 28px;
  }

  .section-heading--compact h2 {
    margin-bottom: 0;
    font-size: 34px;
  }

  .competition-note {
    display: grid;
    grid-template-columns: 34px 1fr;
    gap: 16px;
    align-items: start;
    margin-bottom: 38px;
    padding: 20px 24px;
    color: var(--white);
    background: var(--teal-dark);
    border-left: 7px solid var(--yellow);
  }

  .competition-note svg {
    margin-top: 3px;
    color: var(--yellow);
  }

  .competition-note strong {
    display: block;
    margin-bottom: 4px;
    font-size: 18px;
  }

  .competition-note p {
    max-width: 820px;
    margin-bottom: 0;
    color: rgba(255, 253, 250, 0.78);
  }

  .cfp-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 42px;
    margin-bottom: 10px;
  }

  .cfp-grid article {
    min-width: 0;
    padding-top: 24px;
    border-top: 1px solid var(--line);
  }

  .cfp-grid h3 {
    margin-bottom: 18px;
    font-family: var(--serif);
    font-size: 26px;
    font-weight: 500;
  }

  .check-list,
  .plain-list {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .check-list li {
    display: grid;
    grid-template-columns: 22px 1fr;
    gap: 10px;
    color: var(--ink-soft);
  }

  .check-list li + li,
  .plain-list li + li {
    margin-top: 11px;
  }

  .check-list svg {
    margin-top: 4px;
    color: var(--teal);
  }

  .plain-list li {
    color: var(--ink-soft);
  }

  .cfp-topics {
    margin-top: 42px;
    padding-top: 24px;
    border-top: 1px solid var(--line);
  }

  .cfp-topics h3 {
    margin-bottom: 18px;
    font-family: var(--serif);
    font-size: 26px;
    font-weight: 500;
  }

  .topic-list {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 11px 28px;
  }

  .topic-list li {
    color: var(--ink-soft);
    font-size: 14px;
  }

  .program-shell {
    max-width: 920px;
  }

  .program-section .section-heading {
    max-width: none;
  }

  .program-section .section-heading h2 {
    white-space: nowrap;
  }

  .program-section .section-heading p {
    max-width: none;
    white-space: nowrap;
  }

  .program-preview {
    margin-top: 0;
    border-top: 1px solid var(--line);
  }

  .program-day {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 18px 0;
    color: var(--teal-dark);
    border-bottom: 3px solid var(--teal-dark);
  }

  .program-day span {
    margin-left: auto;
    color: var(--ink-soft);
    font-size: 13px;
  }

  .program-row {
    min-height: 79px;
    display: grid;
    grid-template-columns: 100px 1fr 155px;
    gap: 20px;
    align-items: center;
    border-bottom: 1px solid var(--line);
  }

  .program-row time {
    color: var(--teal);
    font-family: var(--serif);
    font-size: 20px;
  }

  .program-row span {
    font-weight: 650;
  }

  .program-row em {
    color: var(--ink-soft);
    font-size: 12px;
    font-style: normal;
  }

  .sponsorship-head {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 32px;
    margin-bottom: 38px;
  }

  .sponsorship-head .section-heading {
    max-width: 720px;
    margin-bottom: 0;
  }

  .sponsorship-head .button {
    flex-shrink: 0;
  }

  .sponsorship-tiers {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
  }

  .sponsorship-tier {
    min-height: 156px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 24px;
    background: var(--white);
    border-top: 6px solid var(--yellow);
    border-right: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    border-left: 1px solid var(--line);
  }

  .sponsorship-tier span {
    color: var(--teal-dark);
    font-family: var(--serif);
    font-size: 26px;
  }

  .sponsorship-tier p {
    margin-bottom: 0;
    color: var(--ink-soft);
    font-size: 13px;
  }

  .organizer-heading {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 28px;
    margin-bottom: 30px;
  }

  .organizer-heading h2 {
    margin-bottom: 0;
    font-size: 42px;
  }

  .organizer-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }

  .organizer-mini {
    min-width: 0;
    padding: 30px 24px;
    border-right: 1px solid var(--line);
  }

  .organizer-mini:first-child {
    padding-left: 0;
  }

  .organizer-mini:last-child {
    padding-right: 0;
    border-right: 0;
  }

  .organizer-initials {
    width: 46px;
    height: 46px;
    display: grid;
    place-items: center;
    margin-bottom: 18px;
    color: var(--white);
    background: var(--teal);
    border-radius: 50%;
    font-family: var(--serif);
    font-size: 13px;
  }

  .organizer-mini h3 {
    margin-bottom: 8px;
    font-family: var(--serif);
    font-size: 20px;
    font-weight: 500;
  }

  .organizer-email {
    display: inline-block;
    margin-bottom: 11px;
    color: var(--teal-dark);
    font-size: 13px;
    font-weight: 700;
    overflow-wrap: anywhere;
    text-decoration: underline;
    text-decoration-color: rgba(0, 38, 118, 0.24);
    text-underline-offset: 4px;
  }

  .organizer-mini p {
    margin-bottom: 0;
    color: var(--ink-soft);
    font-size: 13px;
  }

  .past-compact {
    display: grid;
    grid-template-columns: 0.6fr 1.4fr;
    gap: 48px;
    align-items: start;
  }

  .past-compact h2 {
    margin-bottom: 0;
    font-size: 34px;
  }

  .past-links {
    margin: 0;
    padding: 0;
    list-style: none;
    border-top: 1px solid var(--line);
  }

  .past-links li {
    min-height: 47px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    border-bottom: 1px solid var(--line);
  }

  .past-links a {
    color: var(--teal-dark);
    font-weight: 750;
    text-decoration-color: rgba(0, 38, 118, 0.25);
  }

  .past-links span {
    color: var(--ink-soft);
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
  }

  @media (max-width: 820px) {
    .home-hero {
      min-height: min(610px, calc(100svh - 150px));
      background-position: 58% center;
    }

    .home-hero h1 {
      font-size: 58px;
    }

    .event-ribbon__grid {
      grid-template-columns: 1fr 1fr;
    }

    .event-ribbon__grid > div {
      padding: 19px 18px;
    }

    .event-ribbon__grid > div:first-child {
      padding-left: 0;
    }

    .event-ribbon__grid > div:nth-child(2) {
      padding-right: 0;
      border-right: 0;
    }

    .deadline-countdown {
      grid-column: 1 / -1;
      padding-left: 0 !important;
      border-top: 1px solid rgba(255, 253, 250, 0.17);
    }

    .intro-grid,
    .cfp-grid {
      grid-template-columns: 1fr;
      gap: 42px;
    }

    .program-section .section-heading h2 {
      white-space: normal;
    }

    .program-section .section-heading p {
      white-space: normal;
    }

    .topic-list {
      grid-template-columns: 1fr;
    }

    .sponsorship-head {
      align-items: flex-start;
      flex-direction: column;
    }

    .sponsorship-tiers {
      grid-template-columns: 1fr;
    }

    .organizer-row {
      grid-template-columns: 1fr 1fr;
    }

    .organizer-mini:nth-child(2) {
      border-right: 0;
    }

    .organizer-mini:nth-child(-n + 2) {
      border-bottom: 1px solid var(--line);
    }

    .organizer-mini:first-child,
    .organizer-mini:last-child {
      padding: 30px 24px;
    }
  }

  @media (max-width: 560px) {
    .home-hero {
      min-height: min(590px, calc(100svh - 142px));
    }

    .home-hero__inner {
      padding-block: 46px;
    }

    .home-hero h1 {
      font-size: 43px;
      overflow-wrap: anywhere;
    }

    .home-hero p {
      font-size: 16px;
    }

    .hero-actions {
      align-items: stretch;
      flex-direction: column;
    }

    .hero-actions .button {
      width: 100%;
    }

    .event-ribbon__grid {
      display: block;
      padding-block: 9px;
    }

    .event-ribbon__grid > div,
    .event-ribbon__grid > div:first-child,
    .event-ribbon__grid > div:last-child {
      min-height: 71px;
      padding: 12px 0;
      border-right: 0;
      border-bottom: 1px solid rgba(255, 253, 250, 0.17);
    }

    .event-ribbon__grid > div:last-child {
      border-bottom: 0;
    }

    .intro-grid h2 {
      font-size: 38px;
    }

    .program-day {
      align-items: flex-start;
      flex-wrap: wrap;
    }

    .program-day span {
      width: 100%;
      margin-left: 31px;
    }

    .program-row {
      grid-template-columns: 68px 1fr;
      gap: 8px 15px;
      padding: 14px 0;
    }

    .program-row em {
      grid-column: 2;
    }

    .past-compact {
      grid-template-columns: 1fr;
      gap: 28px;
    }

    .organizer-heading {
      align-items: flex-start;
      flex-direction: column;
    }

    .organizer-heading h2 {
      font-size: 34px;
    }

    .organizer-row {
      grid-template-columns: 1fr;
    }

