---
import { ArrowRight, ArrowUpRight, CalendarDays, MapPin, Send } from 'lucide-astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import DeadlineTimeline from '@/components/DeadlineTimeline.astro';
import site from '@/data/site.json';
import organizers from '@/data/organizers.json';
import topics from '@/data/topics.json';

const base = import.meta.env.BASE_URL;
const eventJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Event',
  name: `${site.edition} ${site.name}`,
  description: site.description,
  startDate: site.startDate,
  endDate: site.endDate,
  eventStatus: 'https://schema.org/EventScheduled',
  eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
  location: {
    '@type': 'Place',
    name: site.venue,
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'San Francisco',
      addressRegion: 'CA',
      addressCountry: 'US'
    }
  },
  image: [`https://informs-data-mining-society.github.io${base}images/san-francisco-hero.png`],
  organizer: {
    '@type': 'Organization',
    name: site.sponsor,
    url: 'https://connect.informs.org/data-mining/home'
  },
  offers: {
    '@type': 'Offer',
    url: site.registrationUrl,
    availability: 'https://schema.org/InStock',
    validThrough: '2026-10-17T23:59:00-04:00'
  }
};
---

<BaseLayout jsonLd={eventJsonLd}>
  <section class="home-hero" style={`--hero-image: url("${base}images/san-francisco-hero.png")`}>
    <div class="container home-hero__inner">
      <span class="hero-eyebrow">The {site.edition} INFORMS Workshop</span>
      <h1>Data Mining &<br />Decision Analytics</h1>
      <p>A focused day for consequential research at the intersection of data, learning, optimization, and decisions.</p>
      <div class="hero-actions">
        <a class="button button--primary" href={site.submissionUrl} target="_blank" rel="noreferrer">
          <Send size={17} /> Submit a paper <ArrowUpRight size={16} />
        </a>
        <a class="button button--light" href={`${base}call-for-papers/`}>
          Read the call for papers <ArrowRight size={16} />
        </a>
      </div>
    </div>
  </section>

  <section class="event-ribbon" aria-label="Workshop essentials">
    <div class="container event-ribbon__grid">
      <div><CalendarDays size={20} /><span><small>Date</small><strong>{site.date}</strong></span></div>
      <div><MapPin size={20} /><span><small>Location</small><strong>{site.city}</strong></span></div>
      <div class="deadline-countdown" data-deadline="2026-08-01T23:59:00-04:00">
        <span class="countdown-value" aria-hidden="true">11</span>
        <span><small>Paper deadline</small><strong>August 1 · 11:59 PM ET</strong></span>
      </div>
    </div>
  </section>

  <section class="section section--white intro-section">
    <div class="container intro-grid">
      <div>
        <span class="kicker">About the workshop</span>
        <h2>From patterns in data to decisions that matter.</h2>
      </div>
      <div class="intro-copy">
        <p>The INFORMS Data Mining Society invites researchers and practitioners to share recent work in data mining, decision analytics, artificial intelligence, machine learning, optimization, and related methodological and applied areas.</p>
        <p>Held the day before the 2026 INFORMS Annual Meeting, DMDA brings together theoretical advances and field-tested applications in a focused, in-person setting.</p>
        <a class="button button--text" href={site.officialUrl} target="_blank" rel="noreferrer">
          View the official INFORMS listing <ArrowUpRight size={16} />
        </a>
      </div>
    </div>
  </section>

  <section class="section deadline-section">
    <div class="container">
      <div class="section-heading">
        <span class="kicker">Plan ahead</span>
        <h2>Four dates to keep in view.</h2>
        <p>Submissions are reviewed through a double-blind process. Finalists compete in theoretical or applied research tracks.</p>
      </div>
      <DeadlineTimeline />
      <div class="deadline-actions">
        <a class="button button--primary" href={site.submissionUrl} target="_blank" rel="noreferrer">
          Submit through Google Forms <ArrowUpRight size={16} />
        </a>
        <a class="button button--secondary" href={site.cfpUrl} target="_blank" rel="noreferrer">
          View official CFP <ArrowUpRight size={16} />
        </a>
      </div>
    </div>
  </section>

  <section class="section section--ink topic-section">
    <div class="container topic-layout">
      <div class="topic-intro">
        <span class="kicker kicker--light">Scope</span>
        <h2>A broad home for rigorous analytics research.</h2>
        <p>The workshop welcomes methodological contributions and applications across business and society.</p>
      </div>
      <ol class="topic-list">
        {topics.map((topic, index) => (
          <li><span>{String(index + 1).padStart(2, '0')}</span>{topic}</li>
        ))}
      </ol>
    </div>
  </section>

  <section class="section section--white organizer-section">
    <div class="container">
      <div class="organizer-heading">
        <div class="section-heading">
          <span class="kicker">Workshop co-chairs</span>
          <h2>Organized across institutions.</h2>
        </div>
      </div>
      <div class="organizer-row">
        {organizers.map((organizer) => (
          <article class="organizer-mini">
            <span class="organizer-initials" aria-hidden="true">
              {organizer.name.split(' ').map((part) => part[0]).join('')}
            </span>
            <h3>{organizer.name}</h3>
            <a class="organizer-email" href={`mailto:${organizer.email}`}>{organizer.email}</a>
            <p>{organizer.institution}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <script>
    const countdown = document.querySelector<HTMLElement>('[data-deadline]');
    if (countdown) {
      const deadline = new Date(countdown.dataset.deadline ?? '').getTime();
      const days = Math.max(0, Math.ceil((deadline - Date.now()) / 86_400_000));
      const value = countdown.querySelector<HTMLElement>('.countdown-value');
      if (value) {
        value.textContent = String(days);
        value.setAttribute('aria-label', `${days} days until the paper submission deadline`);
      }
    }
  </script>
</BaseLayout>

<style>
  .home-hero {
    position: relative;
    min-height: min(650px, calc(100svh - 154px));
    display: grid;
    align-items: center;
    overflow: hidden;
    color: var(--white);
    background-color: #1e2b29;
    background-image: var(--hero-image);
    background-position: center;
    background-size: cover;
  }

  .home-hero::before {
    position: absolute;
    inset: 0;
    content: '';
    background: rgba(10, 20, 19, 0.62);
  }

  .home-hero__inner {
    position: relative;
    z-index: 1;
    padding-block: 62px;
  }

  .hero-eyebrow {
    display: block;
    margin-bottom: 17px;
    color: var(--yellow);
    font-size: 13px;
    font-weight: 800;
    text-transform: uppercase;
  }

  .home-hero h1 {
    max-width: 880px;
    margin-bottom: 22px;
    font-size: 76px;
    text-wrap: balance;
  }

  .home-hero p {
    max-width: 670px;
    margin-bottom: 30px;
    color: rgba(255, 253, 250, 0.84);
    font-size: 19px;
  }

  .hero-actions,
  .deadline-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .event-ribbon {
    color: var(--white);
    background: var(--teal-dark);
  }

  .event-ribbon__grid {
    min-height: 104px;
    display: grid;
    grid-template-columns: 1fr 1.15fr 1.1fr;
  }

  .event-ribbon__grid > div {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 20px 30px;
    border-right: 1px solid rgba(255, 253, 250, 0.17);
  }

  .event-ribbon__grid > div:first-child {
    padding-left: 0;
  }

  .event-ribbon__grid > div:last-child {
    padding-right: 0;
    border-right: 0;
  }

  .event-ribbon span:not(.countdown-value) {
    display: grid;
  }

  .event-ribbon small {
    color: rgba(255, 253, 250, 0.6);
    font-size: 10px;
    font-weight: 750;
    text-transform: uppercase;
  }

  .event-ribbon strong {
    font-size: 14px;
  }

  .countdown-value {
    min-width: 45px;
    color: var(--yellow);
    font-family: var(--serif);
    font-size: 38px;
    line-height: 1;
  }

  .intro-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 90px;
  }

  .intro-grid h2 {
    margin-bottom: 0;
    font-size: 51px;
  }

  .intro-copy p {
    color: var(--ink-soft);
    font-size: 17px;
  }

  .intro-copy .button {
    margin-top: 9px;
  }

  .deadline-actions {
    margin-top: 30px;
  }

  .topic-layout {
    display: grid;
    grid-template-columns: 0.8fr 1.2fr;
    gap: 100px;
  }

  .topic-intro {
    position: sticky;
    top: 124px;
    align-self: start;
  }

  .topic-intro h2 {
    margin-bottom: 22px;
    font-size: 48px;
  }

  .topic-intro p {
    color: rgba(255, 253, 250, 0.68);
  }

  .topic-list {
    margin: 0;
    padding: 0;
    list-style: none;
    border-top: 1px solid rgba(255, 253, 250, 0.2);
  }

  .topic-list li {
    min-height: 59px;
    display: grid;
    grid-template-columns: 48px 1fr;
    align-items: center;
    gap: 14px;
    border-bottom: 1px solid rgba(255, 253, 250, 0.2);
    font-size: 16px;
  }

  .topic-list span {
    color: var(--yellow);
    font-family: var(--serif);
    font-size: 13px;
  }

  .organizer-heading {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 28px;
  }

  .organizer-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }

  .organizer-mini {
    min-width: 0;
    padding: 30px 24px;
    border-right: 1px solid var(--line);
  }

  .organizer-mini:first-child {
    padding-left: 0;
  }

  .organizer-mini:last-child {
    padding-right: 0;
    border-right: 0;
  }

  .organizer-initials {
    width: 46px;
    height: 46px;
    display: grid;
    place-items: center;
    margin-bottom: 18px;
    color: var(--white);
    background: var(--teal);
    border-radius: 50%;
    font-family: var(--serif);
    font-size: 13px;
  }

  .organizer-mini h3 {
    margin-bottom: 8px;
    font-family: var(--serif);
    font-size: 20px;
    font-weight: 500;
  }

  .organizer-email {
    display: inline-block;
    margin-bottom: 11px;
    color: var(--teal-dark);
    font-size: 13px;
    font-weight: 700;
    overflow-wrap: anywhere;
    text-decoration: underline;
    text-decoration-color: rgba(13, 77, 72, 0.24);
    text-underline-offset: 4px;
  }

  .organizer-mini p {
    margin-bottom: 0;
    color: var(--ink-soft);
    font-size: 13px;
  }

  @media (max-width: 820px) {
    .home-hero {
      min-height: min(610px, calc(100svh - 150px));
      background-position: 58% center;
    }

    .home-hero h1 {
      font-size: 58px;
    }

    .event-ribbon__grid {
      grid-template-columns: 1fr 1fr;
    }

    .event-ribbon__grid > div {
      padding: 19px 18px;
    }

    .event-ribbon__grid > div:first-child {
      padding-left: 0;
    }

    .event-ribbon__grid > div:nth-child(2) {
      padding-right: 0;
      border-right: 0;
    }

    .deadline-countdown {
      grid-column: 1 / -1;
      padding-left: 0 !important;
      border-top: 1px solid rgba(255, 253, 250, 0.17);
    }

    .intro-grid,
    .topic-layout {
      grid-template-columns: 1fr;
      gap: 42px;
    }

    .topic-intro {
      position: static;
    }

    .organizer-row {
      grid-template-columns: 1fr 1fr;
    }

    .organizer-mini:nth-child(2) {
      border-right: 0;
    }

    .organizer-mini:nth-child(-n + 2) {
      border-bottom: 1px solid var(--line);
    }

    .organizer-mini:first-child,
    .organizer-mini:last-child {
      padding: 30px 24px;
    }
  }

  @media (max-width: 560px) {
    .home-hero {
      min-height: min(590px, calc(100svh - 142px));
    }

    .home-hero__inner {
      padding-block: 46px;
    }

    .home-hero h1 {
      font-size: 43px;
      overflow-wrap: anywhere;
    }

    .home-hero p {
      font-size: 16px;
    }

    .hero-actions {
      align-items: stretch;
      flex-direction: column;
    }

    .hero-actions .button {
      width: 100%;
    }

    .event-ribbon__grid {
      display: block;
      padding-block: 9px;
    }

    .event-ribbon__grid > div,
    .event-ribbon__grid > div:first-child,
    .event-ribbon__grid > div:last-child {
      min-height: 71px;
      padding: 12px 0;
      border-right: 0;
      border-bottom: 1px solid rgba(255, 253, 250, 0.17);
    }

    .event-ribbon__grid > div:last-child {
      border-bottom: 0;
    }

    .intro-grid h2,
    .topic-intro h2 {
      font-size: 38px;
    }

    .organizer-heading {
      align-items: flex-start;
      flex-direction: column;
    }

    .organizer-row {
      grid-template-columns: 1fr;
    }

    .organizer-mini,
    .organizer-mini:first-child,
    .organizer-mini:last-child,
    .organizer-mini:nth-child(2) {
      padding: 24px 0;
      border-right: 0;
      border-bottom: 1px solid var(--line);
    }

    .organizer-mini:last-child {
      border-bottom: 0;
    }
  }
</style>
