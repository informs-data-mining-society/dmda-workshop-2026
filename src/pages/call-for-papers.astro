---
import { ArrowUpRight, CheckCircle2, FileText, Send } from 'lucide-astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHero from '@/components/PageHero.astro';
import DeadlineTimeline from '@/components/DeadlineTimeline.astro';
import site from '@/data/site.json';
import topics from '@/data/topics.json';
---

<BaseLayout
  title={`Call for Papers | ${site.shortName}`}
  description="Submit recent research in data mining, decision analytics, artificial intelligence, machine learning, optimization, and related areas to DMDA 2026."
>
  <PageHero
    eyebrow="Submissions open"
    title="Call for Papers"
    intro="Share rigorous new work with the data mining and decision analytics community in San Francisco. The submission deadline is August 1, 2026 at 11:59 PM Eastern Time."
  />

  <section class="section section--white">
    <div class="container detail-layout">
      <article class="prose">
        <span class="kicker">Invitation</span>
        <h2 class="first-heading">Research that moves between insight and action.</h2>
        <p>The INFORMS Data Mining Society invites full-paper submissions presenting recent methodological or applied research in data mining, decision analytics, artificial intelligence, machine learning, optimization, and related fields.</p>
        <p>All accepted papers are automatically considered for the DMDA Workshop Best Paper Competition in either the <strong>Theoretical Track</strong> or <strong>Applied Research Track</strong>, according to the presenter’s specification. Winners and runners-up will be announced at the DMS business meeting and recommended for fast-track submission to the <a href="https://pubsonline.informs.org/journal/ijds" target="_blank" rel="noreferrer">INFORMS Journal on Data Science</a>.</p>

        <h2>Paper format</h2>
        <ul class="format-list">
          <li><CheckCircle2 size={18} /><span>Maximum of 10 pages total, including abstract, tables, figures, references, appendices, and all other material.</span></li>
          <li><CheckCircle2 size={18} /><span>One-inch margins, 11-point font or larger, single-column and single-spaced.</span></li>
          <li><CheckCircle2 size={18} /><span>Include a 50-word abstract.</span></li>
          <li><CheckCircle2 size={18} /><span>Prepare both a blinded and an unblinded PDF.</span></li>
        </ul>

        <h2>Eligibility and review</h2>
        <ul>
          <li>The award nominee or lead author must be a member of the INFORMS Data Mining Society at the time of the 2026 Annual Meeting.</li>
          <li>Submitted work must be neither published nor accepted for publication elsewhere at the time of submission.</li>
          <li>An author may serve as lead author on at most one submission per competition track.</li>
          <li>Review is double-blind. Four finalists will be selected for each track by external referees.</li>
          <li>Final results combine the external review and the oral presentation at the workshop.</li>
          <li>The workshop does not retain copyright in submitted papers.</li>
        </ul>

        <h2>Topics of interest</h2>
        <div class="topic-columns">
          {topics.map((topic) => <span>{topic}</span>)}
        </div>

        <h2>Important dates</h2>
        <DeadlineTimeline />
      </article>

      <aside class="detail-aside" aria-label="Submission actions">
        <Send size={28} strokeWidth={1.6} />
        <h2>Ready to submit?</h2>
        <p>Upload the blinded and unblinded paper files through the organizer-provided Google Form.</p>
        <a class="button button--primary" href={site.submissionUrl} target="_blank" rel="noreferrer">
          Submit a paper <ArrowUpRight size={16} />
        </a>
        <a class="button button--light" href={site.cfpUrl} target="_blank" rel="noreferrer">
          <FileText size={16} /> Official CFP <ArrowUpRight size={15} />
        </a>
        <small>A Google account is required by the submission form.</small>
      </aside>
    </div>
  </section>
</BaseLayout>

<style>
  .first-heading {
    margin-top: 0;
    font-size: 42px;
  }

  .format-list {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .format-list li {
    display: grid;
    grid-template-columns: 22px 1fr;
    gap: 10px;
  }

  .format-list svg {
    margin-top: 4px;
    color: var(--teal);
  }

  .topic-columns {
    display: grid;
    grid-template-columns: 1fr 1fr;
    border-top: 1px solid var(--line);
  }

  .topic-columns span {
    padding: 12px 14px 12px 0;
    color: var(--ink-soft);
    border-bottom: 1px solid var(--line);
    font-size: 14px;
  }

  .detail-aside > svg {
    margin-bottom: 20px;
    color: var(--yellow);
  }

  .detail-aside small {
    display: block;
    margin-top: 18px;
    color: rgba(255, 253, 250, 0.65);
    font-size: 11px;
  }

  :global(.prose .deadline-list) {
    margin-top: 24px;
  }

  :global(.prose .deadline-list li) {
    margin-top: 0;
  }

  @media (max-width: 560px) {
    .first-heading {
      font-size: 34px;
    }

    .topic-columns {
      grid-template-columns: 1fr;
    }
  }
</style>
