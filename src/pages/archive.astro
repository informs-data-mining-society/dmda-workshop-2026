---
import { ArrowUpRight, Archive as ArchiveIcon } from 'lucide-astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHero from '@/components/PageHero.astro';
import archive from '@/data/archive.json';
import site from '@/data/site.json';
---

<BaseLayout title={`Past Workshops | ${site.shortName}`} description="Current and previous editions of the INFORMS Workshop on Data Mining and Decision Analytics.">
  <PageHero eyebrow="A growing series" title="Past Workshops" intro="Explore current and earlier editions of DMDA and the research communities they brought together." />
  <section class="section section--white"><div class="container archive-list">
    <div class="archive-intro"><ArchiveIcon size={24} /><p>The workshop is organized annually by the INFORMS Data Mining Society in conjunction with the INFORMS Annual Meeting.</p></div>
    <a class="archive-row archive-row--current" href={import.meta.env.BASE_URL}><span class="archive-edition">21st</span><span><strong>2026 · San Francisco</strong><small>Current workshop</small></span><ArrowUpRight size={18} /></a>
    {archive.map((event) => <a class="archive-row" href={event.url} target="_blank" rel="noreferrer"><span class="archive-edition">{event.edition}</span><span><strong>{event.year} · {event.city}</strong><small>INFORMS Workshop on Data Mining & Decision Analytics</small></span><ArrowUpRight size={18} /></a>)}
  </div></section>
</BaseLayout>

<style>
  .archive-list { max-width: 900px; }
  .archive-intro { display: grid; grid-template-columns: 30px 1fr; gap: 14px; max-width: 610px; margin-bottom: 42px; color: var(--teal-dark); }
  .archive-intro p { margin-bottom: 0; color: var(--ink-soft); }
  .archive-row { min-height: 105px; display: grid; grid-template-columns: 90px 1fr 24px; gap: 20px; align-items: center; padding: 17px 14px; color: var(--ink); border-top: 1px solid var(--line); text-decoration: none; }
  .archive-row:last-child { border-bottom: 1px solid var(--line); }
  .archive-row:hover { color: var(--teal-dark); background: #edf2ed; }
  .archive-edition { color: var(--red); font-family: var(--serif); font-size: 25px; }
  .archive-row span:nth-child(2) { display: grid; gap: 6px; }
  .archive-row strong { font-size: 17px; }
  .archive-row small { color: var(--ink-soft); font-size: 12px; }
  .archive-row--current { color: var(--white); background: var(--teal-dark); border-color: var(--teal-dark); }
  .archive-row--current .archive-edition { color: var(--yellow); }
  .archive-row--current small { color: rgba(255, 253, 250, .68); }
  .archive-row--current:hover { color: var(--white); background: var(--teal); }
  @media (max-width: 560px) { .archive-row { grid-template-columns: 60px 1fr 20px; gap: 12px; } }
</style>
